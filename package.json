{
  "name": "hello-puzzle",
  "version": "0.9.0",
  "private": true,
  "description": "Sliding tile puzzle (React + Vite). Load a random image via Unsplash API or upload your own. Unrelated to Unsplash branding; see README for API attribution.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "lodash": "^4.17.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "netlify-cli": "^24.6.2",
    "prettier": "^3.8.1",
    "vite": "^7.3.1"
  },
  "scripts": {
    "dev": "netlify dev --no-open --command \"npm run dev:vite\"",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "prettier --write"
  }
}
